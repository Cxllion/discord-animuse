{
    "env": {
        "node": true,
        "es2022": true,
        "jest": true
    },
    "extends": "eslint:recommended",
    "parserOptions": {
        "ecmaVersion": 13
    },
    "rules": {
        "no-unused-vars": ["warn", { "argsIgnorePattern": "^_", "varsIgnorePattern": "^_" }],
        "no-undef": "error",
        "no-console": "off",
        "no-empty": ["warn", { "allowEmptyCatch": true }],
        "no-constant-condition": ["warn", { "checkLoops": false }]
    }
}
