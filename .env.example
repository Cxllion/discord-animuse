# -----------------------------------------------------------------------------
# ANIMUSE BOT ARCHIVES - ENVIRONMENT CONFIGURATION TEMPLATE
# Instructions: Copy this file to '.env' and fill in your library credentials.
# -----------------------------------------------------------------------------

# --- DISCORD CREDENTIALS ---
DISCORD_TOKEN=your_bot_token_here
TEST_DISCORD_TOKEN=your_test_bot_token_here
CLIENT_ID=your_client_id_here
TEST_CLIENT_ID=your_test_client_id_here
GUILD_ID=your_primary_guild_id_here

# --- SUPABASE DATABASE (Postgres) ---
# Used for storing user profiles, leveling data, and guild configurations.
# IMPORTANT: SUPABASE_KEY must be the `service_role` key (NOT the anon key).
# The service_role key has full DB access — keep it secret, server-side only.
DATABASE_URL=postgres://postgres:password@db.supabase.co:6543/postgres
SUPABASE_URL=https://your_project.supabase.co
SUPABASE_KEY=your_supabase_service_role_key_here

# --- ANILIST OAUTH (Optional) ---
ANILIST_CLIENT_ID=your_anilist_client_id_here
ANILIST_CLIENT_SECRET=your_anilist_client_secret_here

# --- NETWORKING (Optional) ---
# Set a port (e.g., 3000) to enable the internal health-check server on Oracle.
# If running on Render, this is REQUIRED.
PORT=

# --- ACCESS CONTROL ---
# Role ID required to access the test bot instance.
# Without this, the test bot will not respond to any interactions.
TESTER_ROLE_ID=your_tester_role_id_here

# --- DEVELOPER LOGGING (Optional) ---
# Webhook URL for critical error alerts forwarded to a developer Discord channel.
LOGS_WEBHOOK_URL=

# --- SERVICE TUNING ---
# Global timeout for AniList API requests in milliseconds (Default: 15000)
ANILIST_TIMEOUT=15000

# --- FEATURE FLAGS ---
# Set to 'true' to force command deployment on every startup.
DEPLOY_ON_START=false
# Set to 'true' to enable DEBUG logging level.
DEBUG=false
# Set to 'true' to disable the internal scheduler (use external cron/worker instead).
DISABLE_INTERNAL_SCHEDULER=false
